# morpho_monitor 最小化配置 — 复制为 .env 后填入即可启动
# 只有 MORPHO_ADMIN_ADDRESS 是必须的，其他都有默认值

# 管理员钱包地址（必填）
MORPHO_ADMIN_ADDRESS=0xYourAdminWalletAddress

# 热钱包私钥（执行清退交易时必填，纯监控可不填）
# MORPHO_HOT_WALLET_KEY=0x...

# JWT 签名密钥（不设则自动生成并持久化到 data/jwt_secret）
# MORPHO_JWT_SECRET=your-secret-here

# 服务端口（默认 16800）
# MORPHO_SERVER_PORT=16800

# GQL 数据源（默认 https://api.morpho.org/graphql）
# MORPHO_GQL_URL=https://api.morpho.org/graphql

# 各链 RPC（可选 — 不配则仅用 GQL 轮询，约 60s 延迟）
# RPC_ETH_HTTP=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_BASE_HTTP=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_OPTIMISM_HTTP=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_ARBITRUM_HTTP=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_UNICHAIN_HTTP=https://mainnet.unichain.org
# RPC_HYPEREVM_HTTP=https://rpc.hyperevm.xyz
